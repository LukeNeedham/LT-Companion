<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/ic_play_pause">

  <target android:name="left_path">
    <aapt:attr name="android:animation">
      <objectAnimator
          android:duration="200"
          android:propertyName="pathData"
          android:valueFrom="M 8,5 L 12.5,8 L 12.5,16 L 8,19 Z"
          android:valueTo="M 6,5 L 10,5 L 10,19 L 6,19 Z"
          android:valueType="pathType"
          android:interpolator="@android:anim/decelerate_interpolator" />
    </aapt:attr>
  </target>

  <target android:name="right_path">
    <aapt:attr name="android:animation">
      <objectAnimator
          android:duration="200"
          android:propertyName="pathData"
          android:valueFrom="M 12.5,8 L 19,12 L 19,12 L 12.5,16 Z"
          android:valueTo="M 14,5 L 18,5 L 18,19 L 14,19 Z"
          android:valueType="pathType"
          android:interpolator="@android:anim/decelerate_interpolator" />
    </aapt:attr>
  </target>
</animated-vector>